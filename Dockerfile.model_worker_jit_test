# Diagnostic test Dockerfile — outputs .nbi counts at each stage so we can
# see exactly where the JIT cache is being created, copied, and whether it
# survives into the final image.
#
# Build:
#   docker buildx build --platform linux/amd64 --load --progress=plain \
#       -f Dockerfile.model_worker_jit_test \
#       -t coreoasis/model_worker:jit-test .
#
# Then verify the final image:
#   docker run --rm --entrypoint bash coreoasis/model_worker:jit-test -c "
#     echo '=== .nbi files in final image ===';
#     find /home/worker/.local -name '*.nbi' | wc -l;
#     echo '=== NUMBA env ===';
#     echo NUMBA_CPU_NAME=\$NUMBA_CPU_NAME;
#     echo '=== sample .nbi paths ===';
#     find /home/worker/.local -name '*.nbi' | head -5;
#     echo '=== source .py mtime (sample) ===';
#     stat /home/worker/.local/lib/python3.12/site-packages/oasislmf/pytools/fm/financial_structure.py | grep Modify;
#   "

# ---- STAGE 1: Build python packages ----
FROM ubuntu:24.04 AS build-packages

ENV PIP_BREAK_SYSTEM_PACKAGES=1
ENV DEBIAN_FRONTEND=noninteractive
# Normalize all pip-installed file timestamps to epoch 0 so they are
# identical across every build — eliminates any mtime drift between stages.
ENV SOURCE_DATE_EPOCH=0

RUN apt-get update && apt-get install -y \
    libspatialindex-dev git curl g++ build-essential \
    libtool autoconf automake python3-dev python3 python3-pip pkg-config \
 && rm -rf /var/lib/apt/lists/*

COPY ./requirements-worker.txt ./requirements-worker.txt
RUN pip3 install --user --no-warn-script-location -r ./requirements-worker.txt

ARG oasislmf_branch
RUN if [ -n "$oasislmf_branch" ]; then \
    pip uninstall oasislmf -y; \
    pip install --user --no-warn-script-location -v \
      git+https://git@github.com/OasisLMF/OasisLMF.git@${oasislmf_branch}#egg=oasislmf[extra]; \
  fi

ARG ods_tools_branch
RUN if [ -n "$ods_tools_branch" ]; then \
    pip uninstall ods-tools -y; \
    pip install --user --no-warn-script-location -v \
      git+https://git@github.com/OasisLMF/ODS_Tools.git@${ods_tools_branch}#egg=ods-tools; \
  fi

ARG odm_branch
RUN if [ -n "$odm_branch" ]; then \
    pip uninstall oasis-data-manager -y; \
    pip install --user --no-warn-script-location -v \
      git+https://git@github.com/OasisLMF/OasisDataManager.git@${odm_branch}#egg=oasis-data-manager; \
  fi

# Normalise all installed file timestamps to epoch 0.
# Numba's cache validates source .py mtimes — if timestamps differ between
# builds (pip uses current time by default), the JIT cache is considered stale.
# Pinning to 0 makes them stable and identical across every build.
RUN find /root/.local -exec touch -d @0 {} +


# ---- STAGE 2: model_worker base ----
FROM ubuntu:24.04 AS model_worker

ENV PIP_BREAK_SYSTEM_PACKAGES=1
ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update \
 && apt-get upgrade -y \
 && apt-get install -y --no-install-recommends \
    vim git python3 python3-pip libspatialindex-dev curl procps ca-certificates \
 && update-ca-certificates \
 && rm -rf /var/lib/apt/lists/*

ARG USER_ID=1000
RUN userdel -r ubuntu \
 && useradd -u ${USER_ID} --home /home/worker --shell /bin/bash worker

COPY --chown=worker:worker --from=build-packages /root/.local /home/worker/.local

WORKDIR /home/worker
COPY ./requirements-worker.txt ./requirements.txt
COPY --chown=worker:worker ./conf.ini ./
COPY ./src/startup_worker.sh ./startup.sh
COPY ./src/__init__.py ./src/
COPY ./src/common ./src/common/
COPY ./src/conf ./src/conf/
COPY ./src/model_execution_worker/ ./src/model_execution_worker/
COPY ./src/utils/ ./src/utils/
COPY ./src/utils/worker_bashrc /home/worker/.bashrc

RUN mkdir -p /var/oasis \
             /home/worker/model \
             /var/log/oasis/tasks \
             /shared-fs \
 && touch /var/log/oasis/worker.log \
 && chmod 777 /var/log/oasis/worker.log \
 && chown -R worker:worker /var/oasis /var/log /shared-fs

COPY ./VERSION ./

USER worker

ENV PATH=/home/worker/.local/bin:$PATH
ENV OASIS_MEDIA_ROOT=/shared-fs
ENV OASIS_ENV_OVERRIDE=true
ENV OASIS_CHECK_MISSING_INPUTS=true

# Diagnostic: confirm source .py mtime is epoch 0 (SOURCE_DATE_EPOCH=0 worked)
RUN stat /home/worker/.local/lib/python3.12/site-packages/oasislmf/pytools/fm/financial_structure.py \
    | grep Modify

ENTRYPOINT ./startup.sh


# ---- STAGE 3: JIT warmup ----
FROM model_worker AS jit-warmup

ENV NUMBA_CPU_NAME=x86-64-v3
SHELL ["/bin/bash", "-o", "pipefail", "-c"]

COPY src/utils/warmup-serial.py /usr/local/bin/warmup-serial.py

WORKDIR /tmp/jit-warmup-cwd

RUN set -e; \
    python3 /usr/local/bin/warmup-serial.py; \
    pytools=/home/worker/.local/lib/python3.12/site-packages/oasislmf/pytools; \
    nbi_count=$(find "${pytools}" -path "*/__pycache__/*.nbi" | wc -l); \
    echo "=== warmup produced ${nbi_count} .nbi files ==="; \
    [ "${nbi_count}" -ge 151 ]; \
    echo "=== sample source mtime after warmup ==="; \
    stat "${pytools}/fm/financial_structure.py" | grep Modify; \
    echo "=== sample .nbi path ==="; \
    find "${pytools}" -name "*.nbi" | head -3


# ---- STAGE 4: Final image ----
FROM model_worker

ENV NUMBA_CPU_NAME=x86-64-v3
ENV OASIS_WORKER_NUMBA_WARMUP=False

RUN --mount=type=bind,from=jit-warmup,source=/home/worker/.local,target=/mnt/jit-local \
    set -e; \
    find /mnt/jit-local \( -name "*.nbi" -o -name "*.nbc" \) | \
    while IFS= read -r src; do \
        dst="/home/worker/.local${src#/mnt/jit-local}"; \
        mkdir -p "$(dirname "$dst")"; \
        cp "$src" "$dst"; \
    done; \
    nbi_count=$(find /home/worker/.local -name "*.nbi" | wc -l); \
    echo "=== final stage has ${nbi_count} .nbi files after mount-copy ==="; \
    [ "${nbi_count}" -ge 151 ]
